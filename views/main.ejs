<!DOCTYPE html>
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="css/style.css">
    <style type="text/css">
      .signup-op a{
        text-decoration: none;
        border: 2px solid #000;
        background-color: rgba(68,241,154,1);
        padding: 8px 20px;
        color: black;
        transition: 0.8s ease;
      }
      .signup-op a:hover{
        background-color: white;
      }
      .slideshow-container {
        margin: 60px auto 0;
        position: relative;
        padding: 0;
        box-sizing: border-box;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        background: #fff;
        max-width: 1200px;
        width: calc(100% - 40px);
      }

      .slides-inner {
        padding: 46px;
        box-sizing: border-box;
      }

      .slideshow-container .mySlides img {
        display: block;
        width: 100%;
        height: auto;
        border-radius: 8px;
      }

      .prev, .next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.55);
        color: #fff;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        border-radius: 50%;
        text-decoration: none;
        z-index: 9999;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        cursor: pointer;
      }

      .prev { left: 14px; }
      .next { right: 14px; }
      .mySlides {
        border-radius: 30px;
      }
    </style>
  </head>
  <body>
    <br> <br>
    <header>
      <div class="main">
        <%- include('partials/header') %>
      </div>
      <div class="slideshow-container">
        <a class="prev" onclick="plusSlides(-1)">&#10094;</a>
        <div class="slides-inner">
          <div class="mySlides fade">
            <img src="/images/front3.jpg" style="width:100%">
          </div>

          <div class="mySlides fade">
            <img src="/images/front2.jpg" style="width:100%">
          </div>

          <div class="mySlides fade">
            <img src="/images/front1.jpg" style="width:100%">
          </div>
        </div>
        <a class="next" onclick="plusSlides(1)">&#10095;</a>
      </div>
    </header>
    <br>

    <div style="text-align:center">
      <span class="dot" onclick="currentSlide(1)"></span> 
      <span class="dot" onclick="currentSlide(2)"></span> 
      <span class="dot" onclick="currentSlide(3)"></span> 
    </div>
    <div class="title">
      <h1>Ultimate tour guide</h1>
   
    </div>
    <br><br>
    <div class="contain">
      <div class="heading">
        <h2>Popular Destination</h2>
      </div>
      <div class="box">
        <div class="imgBox">
          <img src="/images/destination/tajmahal1.jpg" alt="Taj Mahal Image" style="width: auto;height: 270px;">
        </div>
        <div class="name-text left1">
          <h2>Taj Mahal</h2>
          <a href="/destination" class="btn">Visit</a>
        </div>
      </div>
      <div class="box">
        <div class="imgBox">
          <img src="/images/destination/ladakh1.jpg" alt="Ladakh Image" style="width: auto;height: 270px;">
        </div>
        <div class="name-text left2">
          <h2>Ladakh</h2>
          <a href="/destination" class="btn">Visit</a>
        </div>
      </div>
      <div class="box">
        <div class="imgBox">
          <img src="/images/destination/kerala1.jpg" alt="Kerala Image" style="width: auto;height: 270px;">
        </div>
        <div class="name-text left3">
          <h2>Kerala</h2>
          <a href="/destination" class="btn">Visit</a>
        </div>
      </div>
      <div class="box">
        <div class="imgBox">
          <img src="/images/destination/goa1.jpg" alt="Goa Image" style="width: auto;height: 270px;">
        </div>
        <div class="name-text left4">
          <h2>Goa</h2>
          <a href="/destination" class="btn">Visit</a>
        </div>
      </div>
      <div class="destination-btn">
        <a href="destination.ejs">View all</a>
      </div>
    </div>
    <div class="about">
      <h2>About Us</h2>
      <footer>
        <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer">
          <img src="/images/logo/WhatsApp Image 2024-11-25 at 01.29.1facebook3_06f88713.jpg" alt="Facebook" height="25" width="25">
        </a>
        <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer">
          <img src="/images/logo/instagram.jpg" alt="Instagram" height="25" width="25">
        </a>
        <a href="https://twitter.com/" target="_blank" rel="noopener noreferrer">
          <img src="/images/logo/twitter.jpg" alt="Twitter" height="25" width="25">
        </a>
        <p>
          Posted by: Anshu Garg<br>
          Posted by: Aimanpreet Kaur<br>
          Contact: <a href="mailto:anshugarg964@gmail.com">anshugarg964@gmail.com</a><br>
          Contact: <a href="mailto:aimanpreet@gmail.com">aimanpreet@gmail.com</a>
        </p>
      </footer>
    </div>

    <script>
    var slideIndex = 1;
    showSlides(slideIndex);

    function plusSlides(n) {
      showSlides(slideIndex += n);
    }

    function currentSlide(n) {
      showSlides(slideIndex = n);
    }

    function showSlides(n) {
      var i;
      var slides = document.getElementsByClassName("mySlides");
      var dots = document.getElementsByClassName("dot");
      if (n > slides.length) {slideIndex = 1}    
      if (n < 1) {slideIndex = slides.length}
      for (i = 0; i < slides.length; i++) {
          slides[i].style.display = "none";  
      }
      for (i = 0; i < dots.length; i++) {
          dots[i].className = dots[i].className.replace(" active", "");
      }
      slides[slideIndex-1].style.display = "block";  
      dots[slideIndex-1].className += " active";
    }
    </script>

  </body>
</html>